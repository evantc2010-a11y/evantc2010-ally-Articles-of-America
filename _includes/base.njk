<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} | {% endif %}Articles of America</title>
<style>
  :root {
    --navy: #0A1A35;
    --red: #B0303A;
    --paper: #F7F5F0;
    --ink: #1C1C1C;
    --steel: #3D5A80;
    --hairline: #D8D4CC;
    --white: #FFFFFF;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--paper);
    color: var(--ink);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    line-height: 1.4;
  }
  a { color: inherit; text-decoration: none; }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 20px; }
  .utility-bar {
    background: var(--navy);
    color: rgba(255,255,255,0.75);
    font-size: 12.5px;
    letter-spacing: 0.02em;
  }
  .utility-bar .wrap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 34px;
  }
  .utility-bar nav a { margin-left: 16px; color: rgba(255,255,255,0.75); }
  .utility-bar nav a:hover { color: var(--white); }
  .masthead { background: var(--paper); padding: 28px 0 16px; text-align: center; }
  .masthead h1 {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-weight: 700; font-size: 52px;
    letter-spacing: -0.01em; color: var(--navy);
  }
  .masthead a { color: var(--navy); }
  .masthead .tagline {
    font-size: 13px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--steel);
    margin-top: 6px; font-weight: 600;
  }
  .tri-rule {
    height: 5px; width: 100%;
    background: linear-gradient(to right, var(--red) 0 33.33%, var(--white) 33.33% 66.66%, var(--steel) 66.66% 100%);
  }
  .main-nav { background: var(--navy); border-bottom: 3px solid var(--red); }
  .main-nav ul { display: flex; list-style: none; flex-wrap: wrap; }
  .main-nav li a {
    display: block; color: var(--white); font-size: 14px;
    font-weight: 600; letter-spacing: 0.03em;
    padding: 13px 18px; text-transform: uppercase;
  }
  .main-nav li a:hover { background: rgba(255,255,255,0.08); }
  .main-nav li.live a { color: #FFD8D8; }
  .live-dot {
    display: inline-block; width: 7px; height: 7px;
    border-radius: 50%; background: var(--red);
    margin-right: 6px; animation: pulse 1.8s infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
  footer {
    background: var(--navy); color: rgba(255,255,255,0.7);
    margin-top: 50px; padding: 36px 0 28px; font-size: 13px;
  }
  footer .wrap { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 20px; }
  footer .brand { font-family: Georgia, serif; font-size: 20px; color: var(--white); font-weight: 700; }
  footer .cols { display: flex; gap: 40px; flex-wrap: wrap; }
  footer .cols a { display: block; margin-bottom: 8px; color: rgba(255,255,255,0.65); }
  footer .cols a:hover { color: var(--white); }
  footer .legal { text-align: center; margin-top: 28px; color: rgba(255,255,255,0.4); font-size: 12px; }
  @media (max-width: 860px) { .masthead h1 { font-size: 38px; } }
  @media (max-width: 560px) {
    .utility-bar nav a { margin-left: 10px; }
    .main-nav ul { overflow-x: auto; flex-wrap: nowrap; }
  }
</style>
{% block extraStyles %}{% endblock %}
</head>
<body>

<div class="utility-bar">
  <div class="wrap">
    <span id="todayDate"></span>
    <nav>
      <a href="#">Newsletter</a>
      <a href="#">Sign In</a>
      <a href="#">Subscribe</a>
    </nav>
  </div>
</div>

<header class="masthead">
  <h1><a href="/">Articles of America</a></h1>
  <p class="tagline">Clear reporting. Every story, straight.</p>
</header>

<div class="tri-rule"></div>

<nav class="main-nav">
  <div class="wrap">
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/category/us/">U.S.</a></li>
      <li><a href="/category/world/">World</a></li>
      <li><a href="/category/politics/">Politics</a></li>
      <li><a href="/category/weather/">Weather</a></li>
      <li><a href="/category/business/">Business</a></li>
      <li><a href="/category/tech/">Tech</a></li>
      <li><a href="/category/sports/">Sports</a></li>
      <li class="live"><a href="#"><span class="live-dot"></span>Live</a></li>
    </ul>
  </div>
</nav>

{% block content %}{% endblock %}

<footer>
  <div class="wrap">
    <div>
      <p class="brand">Articles of America</p>
    </div>
    <div class="cols">
      <div>
        <a href="/about/">About Us</a>
        <a href="#">Newsroom Ethics</a>
        <a href="#">Careers</a>
      </div>
      <div>
        <a href="#">Contact</a>
        <a href="#">Advertise</a>
        <a href="#">Privacy Policy</a>
      </div>
      <div>
        <a href="#">RSS</a>
        <a href="#">Newsletter</a>
        <a href="#">Sitemap</a>
      </div>
    </div>
  </div>
  <p class="legal">© 2026 Articles of America. All rights reserved.</p>
</footer>

<script>
  document.getElementById('todayDate').textContent = new Date().toLocaleDateString('en-US', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
  });
</script>
</body>
</html>
